{
  "name": "CloudRush",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$path": "src/ReplicatedStorage"
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "$path": "src/ServerScriptService"
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "$path": "src/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "Gravity": 140,
        "FilteringEnabled": true
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Technology": "Future",
        "Brightness": 2,
        "ClockTime": 15.2,
        "GeographicLatitude": 41,
        "ExposureCompensation": 0,
        "Ambient": [0.06, 0.07, 0.10],
        "OutdoorAmbient": [0.44, 0.51, 0.66],
        "EnvironmentDiffuseScale": 0.55,
        "EnvironmentSpecularScale": 0.6,
        "GlobalShadows": true,
        "ShadowSoftness": 0.35,
        "FogEnd": 100000
      },

      "Atmosphere": {
        "$className": "Atmosphere",
        "$properties": {
          "Density": 0.3,
          "Offset": 0,
          "Color": [0.72, 0.80, 0.95],
          "Decay": [0.53, 0.62, 0.80],
          "Glare": 0.2,
          "Haze": 1.05
        }
      },

      "Bloom": {
        "$className": "BloomEffect",
        "$properties": {
          "Intensity": 0.35,
          "Size": 20,
          "Threshold": 1.9
        }
      },

      "DoF": {
        "$className": "DepthOfFieldEffect",
        "$properties": {
          "FarIntensity": 0.28,
          "FocusDistance": 40,
          "InFocusRadius": 95,
          "NearIntensity": 0
        }
      },

      "Grade": {
        "$className": "ColorCorrectionEffect",
        "$properties": {
          "Brightness": -0.02,
          "Contrast": 0.16,
          "Saturation": 0.06,
          "TintColor": [0.98, 0.99, 1.0]
        }
      },

      "SunRays": {
        "$className": "SunRaysEffect",
        "$properties": {
          "Intensity": 0.08,
          "Spread": 0.6
        }
      },

      "Sky": {
        "$className": "Sky",
        "$properties": {
          "SunAngularSize": 12,
          "MoonAngularSize": 0,
          "StarCount": 0,
          "CelestialBodiesShown": true
        }
      }
    }
  }
}
